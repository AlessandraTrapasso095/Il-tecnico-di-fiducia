NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional (recommended in production): canonical site URL used for redirects in emails
NEXT_PUBLIC_SITE_URL=

# Server-only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (server-only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_SUBSCRIPTION_PRICE_ID=


# Optional: allow running /api/stripe/reconcile via Bearer secret (for cron jobs)
STRIPE_RECONCILE_SECRET=

# Optional: salt for hashing rate-limit identifiers (emails) stored in DB
RATE_LIMIT_SALT=

# Optional/manual admin bootstrap reference values (do not expose in frontend)
INITIAL_ADMIN_EMAIL=admin@iltecnicodifiducia.it
INITIAL_ADMIN_TEMP_PASSWORD=

# Optional transactional email provider used by app-side emails (support tickets, etc.).
# Supabase Auth emails still use Supabase SMTP settings.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=ricettetaglisicuri@gmail.com
SMTP_PASS=
EMAIL_FROM="Il Tecnico di Fiducia <ricettetaglisicuri@gmail.com>"
SUPPORT_ADMIN_EMAIL=admin@iltecnicodifiducia.it
