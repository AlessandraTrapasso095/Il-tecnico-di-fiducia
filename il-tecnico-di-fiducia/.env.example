NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional (recommended in production): canonical site URL used for redirects in emails
NEXT_PUBLIC_SITE_URL=

# Server-only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (server-only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_SUBSCRIPTION_PRICE_ID=


# Optional: allow running /api/stripe/reconcile via Bearer secret (for cron jobs)
STRIPE_RECONCILE_SECRET=

# Optional: salt for hashing rate-limit identifiers (emails) stored in DB
RATE_LIMIT_SALT=
